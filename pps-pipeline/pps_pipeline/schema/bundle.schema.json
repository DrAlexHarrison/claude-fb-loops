{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fb-loops.example/pps/bundle.schema.json",
  "title": "SessionBundle manifest",
  "description": "The capture<->pipeline contract (the swap point). A single clock origin t0; every stream carries offsets relative to t0 (or absolute timestamps the loader normalizes to t0).",
  "type": "object",
  "required": ["schema_version", "session_id", "t0_epoch", "duration_s", "streams"],
  "properties": {
    "schema_version": { "type": "string" },
    "session_id": { "type": "string", "minLength": 1 },
    "t0_epoch": { "type": "number", "description": "single clock origin (unix epoch seconds)" },
    "duration_s": { "type": "number", "minimum": 0 },
    "consent": {
      "description": "PLACEHOLDER — legal/consent framing is v-next/written-pitch, not core.",
      "type": "object",
      "properties": {
        "obtained": { "type": "boolean" },
        "scope": { "type": "string" },
        "ref": { "type": "string" }
      },
      "additionalProperties": true
    },
    "streams": {
      "type": "object",
      "description": "Stream descriptors. 'present' gates whether the pipeline loads the ref.",
      "properties": {
        "video":       { "$ref": "#/$defs/stream" },
        "transcript":  { "$ref": "#/$defs/stream" },
        "captions":    { "$ref": "#/$defs/stream" },
        "network":     { "$ref": "#/$defs/stream" },
        "ccode_session": { "$ref": "#/$defs/stream" },
        "events":      { "$ref": "#/$defs/stream" }
      },
      "additionalProperties": { "$ref": "#/$defs/stream" }
    },
    "redaction": {
      "type": "object",
      "properties": { "applied": { "type": "boolean" } },
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "$defs": {
    "stream": {
      "type": "object",
      "required": ["present"],
      "properties": {
        "ref": { "type": "string" },
        "present": { "type": "boolean" },
        "engine": { "type": "string" },
        "fps": { "type": "number" },
        "time_base": {
          "description": "How this stream stamps time. 'offset' = seconds from t0; 'epoch' = unix epoch seconds; 'iso' = ISO-8601 absolute. Loader normalizes all to offsets.",
          "type": "string",
          "enum": ["offset", "epoch", "iso"]
        }
      },
      "additionalProperties": true
    }
  }
}
