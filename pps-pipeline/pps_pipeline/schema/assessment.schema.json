{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fb-loops.example/pps/assessment.schema.json",
  "title": "Assessment",
  "description": "The deliverable intelligence: a structured, evidence-cited assessment. Every dimension score MUST cite >=1 timestamped quote (the no-fabrication gate).",
  "type": "object",
  "required": ["schema_version", "session_id", "rubric_version", "dimensions", "overall", "confidence", "evidence_complete"],
  "properties": {
    "schema_version": { "type": "string" },
    "session_id": { "type": "string", "minLength": 1 },
    "rubric_version": { "type": "string" },
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/dimension" }
    },
    "strengths": { "type": "array", "items": { "type": "string" } },
    "gaps": { "type": "array", "items": { "type": "string" } },
    "overall": { "type": "string", "minLength": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidence_complete": { "type": "boolean" }
  },
  "additionalProperties": true,
  "$defs": {
    "dimension": {
      "type": "object",
      "required": ["name", "score", "evidence", "rationale"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "score": { "type": "integer", "minimum": 1, "maximum": 5 },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" }
        },
        "rationale": { "type": "string" }
      },
      "additionalProperties": true
    },
    "evidence": {
      "type": "object",
      "required": ["t", "quote"],
      "properties": {
        "t": { "type": "number", "minimum": 0 },
        "quote": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    }
  }
}
