{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fb-loops.example/fb-os/open-questions.schema.json",
  "title": "open-questions.json",
  "description": "The living org-authored question list Build 1 publishes and Build 3's /fb consumes. THE seam contract.",
  "type": "object",
  "required": ["schema_version", "generated_at", "questions"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "generated_at": { "type": "string", "format": "date-time" },
    "generator": { "type": "string" },
    "source_window": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "artifacts": { "type": "integer", "minimum": 0 },
        "since": { "type": "string" },
        "until": { "type": "string" }
      }
    },
    "questions": {
      "type": "array",
      "items": { "$ref": "#/$defs/question" }
    }
  },
  "$defs": {
    "question": {
      "type": "object",
      "required": ["id", "question", "match", "priority", "status"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^oq_[0-9]{4}w[0-9]{2}_[0-9]{2,}$",
          "description": "Stable id: oq_<ISO-week>_<seq>. Survives regeneration."
        },
        "question": { "type": "string", "minLength": 1 },
        "hypothesis": { "type": "string" },
        "cluster_id": { "type": "string" },
        "cluster_label": { "type": "string" },
        "match": {
          "type": "object",
          "required": ["keywords", "surfaces"],
          "additionalProperties": false,
          "properties": {
            "keywords": { "type": "array", "items": { "type": "string" } },
            "surfaces": {
              "type": "array",
              "items": { "type": "string", "enum": ["cli", "ide", "claude.ai", "api", "cowork"] }
            },
            "embedding_ref": { "type": ["string", "null"] }
          }
        },
        "priority": { "type": "number", "minimum": 0, "maximum": 1 },
        "uncertainty": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence_count": { "type": "integer", "minimum": 0 },
        "status": { "type": "string", "enum": ["open", "answered", "retired"] },
        "created_at": { "type": "string" },
        "expires_at": { "type": "string" },
        "provenance": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "artifact_ids": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    }
  }
}
